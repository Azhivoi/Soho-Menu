<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Склад | SOHO CRM</title>
    <style>
        :root {
            --bg-primary: #0f0f1a;
            --bg-secondary: #1a1a2e;
            --bg-card: #252538;
            --bg-hover: #2d2d45;
            --accent-red: #e94560;
            --accent-green: #00d9a5;
            --accent-orange: #f39c12;
            --accent-blue: #3498db;
            --text-primary: #ffffff;
            --text-secondary: #a0a0b8;
            --border-color: #33334d;
        }
        
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            min-height: 100vh;
        }
        
        /* Layout */
        .crm-layout { display: flex; min-height: 100vh; }
        
            width: 260px;
            background: var(--bg-secondary);
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
        }
        
        .sidebar-header {
            padding: 20px;
            border-bottom: 1px solid var(--border-color);
        }
        
        .sidebar-header h1 {
            font-size: 24px;
            font-weight: 800;
        }
        
        .sidebar-header h1 span { color: var(--accent-red); }
        
        .sidebar-nav {
            flex: 1;
            padding: 16px 0;
        }
        
        .nav-section { margin-bottom: 8px; }
        
        .nav-section-title {
            padding: 12px 20px;
            font-size: 11px;
            text-transform: uppercase;
            color: var(--text-secondary);
            font-weight: 600;
            letter-spacing: 0.5px;
        }
        
        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 20px;
            color: var(--text-secondary);
            text-decoration: none;
            transition: all 0.2s;
            border-left: 3px solid transparent;
        }
        
        .nav-item:hover, .nav-item.active {
    <style>
        :root {
            --sidebar-width: 280px;
            --sidebar-bg: #1a1a2e;
            --sidebar-border: #2a2a40;
            --text-primary: #ffffff;
            --text-secondary: #a0a0b0;
            --accent: #e94560;
            --accent-hover: #ff6b6b;
            --hover-bg: rgba(233, 69, 96, 0.1);
            --border-color: #2a2a40;
            --bg-primary: #0f0f1a;
            --bg-secondary: #1a1a2e;
            --bg-hover: rgba(255,255,255,0.05);
        }
        
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
        }
        
        .crm-layout {
            display: flex;
            min-height: 100vh;
        }
        
        /* Unified Sidebar */
        .unified-sidebar {
            width: var(--sidebar-width);
            background: var(--sidebar-bg);
            border-right: 1px solid var(--sidebar-border);
            display: flex;
            flex-direction: column;
            position: fixed;
            left: 0;
            top: 0;
            bottom: 0;
            overflow-y: auto;
            z-index: 100;
        }
        
        .sidebar-logo {
            padding: 24px 20px;
            border-bottom: 1px solid var(--sidebar-border);
        }
        
        .sidebar-logo h1 {
            font-size: 22px;
            font-weight: 800;
        }
        
        .sidebar-logo h1 span { color: var(--accent); }
        
        .sidebar-nav {
            flex: 1;
            padding: 12px 0;
        }
        
        .nav-section {
            border-bottom: 1px solid var(--sidebar-border);
        }
        
        .nav-section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 20px;
            cursor: pointer;
            transition: all 0.2s;
            user-select: none;
        }
        
        .nav-section-header:hover { background: var(--hover-bg); }
        
        .nav-section-title {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 14px;
            font-weight: 600;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .nav-section-icon {
            font-size: 20px;
            width: 24px;
            text-align: center;
        }
        
        .nav-section-arrow {
            font-size: 12px;
            color: var(--text-secondary);
            transition: transform 0.3s;
        }
        
        .nav-section.expanded .nav-section-arrow {
            transform: rotate(90deg);
        }
        
        .nav-submenu {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease-out;
            background: rgba(0, 0, 0, 0.2);
        }
        
        .nav-section.expanded .nav-submenu {
            max-height: 500px;
            transition: max-height 0.3s ease-in;
        }
        
        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 20px 12px 56px;
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 14px;
            transition: all 0.2s;
            border-left: 3px solid transparent;
        }
        
        .nav-item:hover {
            background: var(--hover-bg);
            color: var(--text-primary);
        }
        
        .nav-item.active {
            background: var(--hover-bg);
            color: var(--accent);
            border-left-color: var(--accent);
        }
        
        .nav-item-icon {
            font-size: 16px;
            width: 20px;
            text-align: center;
        }
        
        .sidebar-footer {
            padding: 16px 20px;
            border-top: 1px solid var(--sidebar-border);
            margin-top: auto;
        }
        
        .user-card {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        
        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: var(--accent);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 14px;
        }
        
        .user-info { flex: 1; }
        
        .user-name {
            font-weight: 600;
            font-size: 14px;
        }
        
        .user-role {
            font-size: 12px;
            color: var(--text-secondary);
        }
        
        .crm-main {
            flex: 1;
            margin-left: var(--sidebar-width);
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }
        
        .top-bar {
            height: 64px;
            background: var(--sidebar-bg);
            border-bottom: 1px solid var(--sidebar-border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 24px;
            position: sticky;
            top: 0;
            z-index: 50;
        }
        
        .top-bar h2 {
            font-size: 20px;
            font-weight: 600;
        }
        
        .top-actions {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        
        .sidebar-toggle {
            display: none;
            position: fixed;
            top: 20px;
            left: 20px;
            z-index: 200;
            background: var(--accent);
            border: none;
            padding: 10px;
            border-radius: 8px;
            color: white;
            cursor: pointer;
        }
        
        @media (max-width: 1024px) {
        /* Content Area */
        .inventory-content {
            flex: 1;
            padding: 24px;
            overflow-y: auto;
        }
        
        .inventory-table-container {
            background: var(--bg-secondary);
            border-radius: 12px;
            border: 1px solid var(--sidebar-border);
            overflow: hidden;
            margin-top: 20px;
        }
        
        .inventory-table {
            width: 100%;
            border-collapse: collapse;
        }
        
        .inventory-table th,
        .inventory-table td {
            padding: 16px;
            text-align: left;
            border-bottom: 1px solid var(--sidebar-border);
        }
        
        .inventory-table th {
            background: rgba(0,0,0,0.2);
            font-weight: 600;
            color: var(--text-secondary);
        }
        
        .inventory-table tr:hover {
            background: var(--hover-bg);
        }
        
        /* Stats */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 24px;
        }
        
        .stat-card {
            background: var(--bg-secondary);
            border-radius: 12px;
            padding: 20px;
            border: 1px solid var(--sidebar-border);
        }
        
        .stat-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
        }
        
        .stat-title {
            font-size: 14px;
            color: var(--text-secondary);
        }
        
        .stat-icon {
            font-size: 24px;
        }
        
        .stat-value {
            font-size: 32px;
            font-weight: 700;
            margin-bottom: 4px;
        }
        
        .stat-desc {
            font-size: 13px;
            color: var(--text-secondary);
        }
        
        /* Alert Banner */
        .alert-banner {
            background: rgba(233, 69, 96, 0.1);
            border: 1px solid var(--accent);
            border-radius: 12px;
            padding: 16px 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 20px;
        }
        
        .alert-banner .icon {
            font-size: 24px;
        }
        
        /* Buttons */
        .btn {
            padding: 10px 20px;
            border-radius: 8px;
            border: none;
            cursor: pointer;
            font-size: 14px;
            font-weight: 600;
            transition: all 0.2s;
        }
        
        .btn-primary {
            background: var(--accent);
            color: white;
        }
        
        .btn-primary:hover {
            background: var(--accent-hover);
        }
        
        .btn-secondary {
            background: transparent;
            color: var(--text-secondary);
            border: 1px solid var(--sidebar-border);
        }
        
        .btn-secondary:hover {
            border-color: var(--accent);
            color: var(--text-primary);
        }
        
        /* Search Box */
        .search-box {
            display: flex;
            align-items: center;
            gap: 10px;
            background: rgba(255,255,255,0.05);
            padding: 10px 16px;
            border-radius: 8px;
            border: 1px solid var(--sidebar-border);
        }
        
        .search-box input {
            background: transparent;
            border: none;
            color: var(--text-primary);
            font-size: 14px;
            outline: none;
            width: 200px;
        }
        
        .search-box input::placeholder {
            color: var(--text-secondary);
        }
            .unified-sidebar {
                transform: translateX(-100%);
                transition: transform 0.3s;
            }
            
            .unified-sidebar.open { transform: translateX(0); }
            
            .crm-main { margin-left: 0; }
            
            .sidebar-toggle { display: block; }
        }
        
        .sidebar-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.5);
            z-index: 99;
        }
        
        @media (max-width: 1024px) {
        /* Content Area */
        .inventory-content {
            flex: 1;
            padding: 24px;
            overflow-y: auto;
        }
        
        .inventory-table-container {
            background: var(--bg-secondary);
            border-radius: 12px;
            border: 1px solid var(--sidebar-border);
            overflow: hidden;
            margin-top: 20px;
        }
        
        .inventory-table {
            width: 100%;
            border-collapse: collapse;
        }
        
        .inventory-table th,
        .inventory-table td {
            padding: 16px;
            text-align: left;
            border-bottom: 1px solid var(--sidebar-border);
        }
        
        .inventory-table th {
            background: rgba(0,0,0,0.2);
            font-weight: 600;
            color: var(--text-secondary);
        }
        
        .inventory-table tr:hover {
            background: var(--hover-bg);
        }
        
        /* Stats */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 24px;
        }
        
        .stat-card {
            background: var(--bg-secondary);
            border-radius: 12px;
            padding: 20px;
            border: 1px solid var(--sidebar-border);
        }
        
        .stat-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
        }
        
        .stat-title {
            font-size: 14px;
            color: var(--text-secondary);
        }
        
        .stat-icon {
            font-size: 24px;
        }
        
        .stat-value {
            font-size: 32px;
            font-weight: 700;
            margin-bottom: 4px;
        }
        
        .stat-desc {
            font-size: 13px;
            color: var(--text-secondary);
        }
        
        /* Alert Banner */
        .alert-banner {
            background: rgba(233, 69, 96, 0.1);
            border: 1px solid var(--accent);
            border-radius: 12px;
            padding: 16px 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 20px;
        }
        
        .alert-banner .icon {
            font-size: 24px;
        }
        
        /* Buttons */
        .btn {
            padding: 10px 20px;
            border-radius: 8px;
            border: none;
            cursor: pointer;
            font-size: 14px;
            font-weight: 600;
            transition: all 0.2s;
        }
        
        .btn-primary {
            background: var(--accent);
            color: white;
        }
        
        .btn-primary:hover {
            background: var(--accent-hover);
        }
        
        .btn-secondary {
            background: transparent;
            color: var(--text-secondary);
            border: 1px solid var(--sidebar-border);
        }
        
        .btn-secondary:hover {
            border-color: var(--accent);
            color: var(--text-primary);
        }
        
        /* Search Box */
        .search-box {
            display: flex;
            align-items: center;
            gap: 10px;
            background: rgba(255,255,255,0.05);
            padding: 10px 16px;
            border-radius: 8px;
            border: 1px solid var(--sidebar-border);
        }
        
        .search-box input {
            background: transparent;
            border: none;
            color: var(--text-primary);
            font-size: 14px;
            outline: none;
            width: 200px;
        }
        
        .search-box input::placeholder {
            color: var(--text-secondary);
        }
            .sidebar-overlay.open { display: block; }
        }
    </style>
</head>
<body>
    <div class="crm-layout">
        <!-- Unified Sidebar -->
        <aside class="unified-sidebar" id="sidebar">
            <div class="sidebar-logo">
                <h1><span>SOHO</span> Admin</h1>
            </div>
            
            <nav class="sidebar-nav">
                <!-- Orders Section -->
                <div class="nav-section" data-section="orders">
                    <div class="nav-section-header" onclick="toggleSection(this)">
                        <div class="nav-section-title">
                            <span class="nav-section-icon">📝</span>
                            <span>Заказы</span>
                        </div>
                        <span class="nav-section-arrow">▶</span>
                    </div>
                    <div class="nav-submenu">
                        <a href="crm-orders.html" class="nav-item">
                            <span class="nav-item-icon">📋</span>
                            <span>Все заказы</span>
                        </a>
                        <a href="crm-new-order.html" class="nav-item">
                            <span class="nav-item-icon">➕</span>
                            <span>Новый заказ</span>
                        </a>
                        <a href="crm-kds.html" class="nav-item">
                            <span class="nav-item-icon">👨‍🍳</span>
                            <span>KDS Экран</span>
                        </a>
                    </div>
                </div>
                
                <!-- Catalog Section -->
                <div class="nav-section" data-section="catalog">
                    <div class="nav-section-header" onclick="toggleSection(this)">
                        <div class="nav-section-title">
                            <span class="nav-section-icon">🍽️</span>
                            <span>Каталог</span>
                        </div>
                        <span class="nav-section-arrow">▶</span>
                    </div>
                    <div class="nav-submenu">
                        <a href="crm-menu-products.html" class="nav-item">
                            <span class="nav-item-icon">🍕</span>
                            <span>Товары</span>
                        </a>
                        <a href="crm-menu-categories.html" class="nav-item">
                            <span class="nav-item-icon">📁</span>
                            <span>Категории</span>
                        </a>
                        <a href="crm-menu-ingredients.html" class="nav-item">
                            <span class="nav-item-icon">🥬</span>
                            <span>Ингредиенты</span>
                        </a>
                        <a href="crm-recipes.html" class="nav-item">
                            <span class="nav-item-icon">📖</span>
                            <span>Рецепты</span>
                        </a>
                    </div>
                </div>
                
                <!-- Warehouse Section - Expanded by default -->
                <div class="nav-section expanded" data-section="warehouse">
                    <div class="nav-section-header" onclick="toggleSection(this)">
                        <div class="nav-section-title">
                            <span class="nav-section-icon">📦</span>
                            <span>Склад</span>
                        </div>
                        <span class="nav-section-arrow">▶</span>
                    </div>
                    <div class="nav-submenu">
                        <a href="crm-warehouse.html" class="nav-item">
                            <span class="nav-item-icon">📊</span>
                            <span>Дашборд</span>
                        </a>
                        <a href="crm-inventory.html" class="nav-item active">
                            <span class="nav-item-icon">📋</span>
                            <span>Остатки</span>
                        </a>
                        <a href="crm-warehouse-invoices.html" class="nav-item">
                            <span class="nav-item-icon">📄</span>
                            <span>Накладные</span>
                        </a>
                        <a href="crm-warehouse-suppliers.html" class="nav-item">
                            <span class="nav-item-icon">🏢</span>
                            <span>Поставщики</span>
                        </a>
                        <a href="crm-warehouse-movements.html" class="nav-item">
                            <span class="nav-item-icon">🔄</span>
                            <span>Движения</span>
                        </a>
                    </div>
                </div>
                
                <!-- Customers Section -->
                <div class="nav-section" data-section="customers">
                    <div class="nav-section-header" onclick="toggleSection(this)">
                        <div class="nav-section-title">
                            <span class="nav-section-icon">👥</span>
                            <span>Клиенты</span>
                        </div>
                        <span class="nav-section-arrow">▶</span>
                    </div>
                    <div class="nav-submenu">
                        <a href="crm-customers.html" class="nav-item">
                            <span class="nav-item-icon">👤</span>
                            <span>База клиентов</span>
                        </a>
                        <a href="crm-stats-customers.html" class="nav-item">
                            <span class="nav-item-icon">📈</span>
                            <span>Статистика</span>
                        </a>
                    </div>
                </div>
                
                <!-- Analytics Section -->
                <div class="nav-section" data-section="analytics">
                    <div class="nav-section-header" onclick="toggleSection(this)">
                        <div class="nav-section-title">
                            <span class="nav-section-icon">📊</span>
                            <span>Аналитика</span>
                        </div>
                        <span class="nav-section-arrow">▶</span>
                    </div>
                    <div class="nav-submenu">
                        <a href="crm-dashboard.html" class="nav-item">
                            <span class="nav-item-icon">📈</span>
                            <span>Дашборд</span>
                        </a>
                        <a href="crm-stats.html" class="nav-item">
                            <span class="nav-item-icon">📉</span>
                            <span>Отчёты</span>
                        </a>
                    </div>
                </div>
                
                <!-- Settings Section -->
                <div class="nav-section" data-section="settings">
                    <div class="nav-section-header" onclick="toggleSection(this)">
                        <div class="nav-section-title">
                            <span class="nav-section-icon">⚙️</span>
                            <span>Настройки</span>
                        </div>
                        <span class="nav-section-arrow">▶</span>
                    </div>
                    <div class="nav-submenu">
                        <a href="admin-panel.html" class="nav-item">
                            <span class="nav-item-icon">🔧</span>
                            <span>Панель управления</span>
                        </a>
                        <a href="crm-employees.html" class="nav-item">
                            <span class="nav-item-icon">👷</span>
                            <span>Сотрудники</span>
                        </a>
                        <a href="crm-settings-marks.html" class="nav-item">
                            <span class="nav-item-icon">🏷️</span>
                            <span>Метки заказов</span>
                        </a>
                    </div>
                </div>
            </nav>
            
            <div class="sidebar-footer">
                <div class="user-card">
                    <div class="user-avatar">АД</div>
                    <div class="user-info">
                        <div class="user-name">Админ</div>
                        <div class="user-role">SOHO Cafe</div>
                    </div>
                </div>
            </div>
        </aside>
        
        <!-- Mobile Overlay -->
        <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>
        
        <!-- Mobile Toggle Button -->
        <button class="sidebar-toggle" id="sidebarToggle" onclick="toggleSidebar()">☰</button>
        
        <!-- Main Content -->
        <main class="crm-main">
            <!-- Top Bar -->
            <header class="top-bar">
                <h2>📦 Управление складом</h2>
                <div class="top-actions">
                    <div class="search-box">
                        <span>🔍</span>
                        <input type="text" id="searchInput" placeholder="Поиск по товарам..." oninput="filterProducts()">
                    </div>
                    <button class="btn btn-secondary" onclick="exportInventory()">📥 Экспорт</button>
                    <button class="btn btn-primary" onclick="openStockModal()">+ Приход</button>
                </div>
            </header>
            
            <!-- Content -->
            <div class="inventory-content">
                <!-- Alert Banner -->
                <div class="alert-banner" id="alertBanner" style="display: none;">
                    <span class="icon">⚠️</span>
                    <div>
                        <h4>Внимание! Заканчиваются товары</h4>
                        <p id="alertText">5 товаров ниже критического уровня запасов</p>
                    </div>
                </div>
                
                <!-- Stats -->
                <div class="stats-row">
                    <div class="stat-card">
                        <div class="stat-header">
                            <span class="stat-title">Всего позиций</span>
                            <div class="stat-icon blue">📦</div>
                        </div>
                        <div class="stat-value" id="totalItems">0</div>
                        <div class="stat-desc">На складе</div>
                    </div>
                    
                    <div class="stat-card">
                        <div class="stat-header">
                            <span class="stat-title">В наличии</span>
                            <div class="stat-icon green">✅</div>
                        </div>
                        <div class="stat-value" id="inStock">0</div>
                        <div class="stat-desc">Доступно для продажи</div>
                    </div>
                    
                    <div class="stat-card warning">
                        <div class="stat-header">
                            <span class="stat-title">Заканчивается</span>
                            <div class="stat-icon orange">⚠️</div>
                        </div>
                        <div class="stat-value" id="lowStock">0</div>
                        <div class="stat-desc">Ниже минимального уровня</div>
                    </div>
                    
                    <div class="stat-card danger">
                        <div class="stat-header">
                            <span class="stat-title">Нет в наличии</span>
                            <div class="stat-icon red">❌</div>
                        </div>
                        <div class="stat-value" id="outOfStock">0</div>
                        <div class="stat-desc">Требуется пополнение</div>
                    </div>
                </div>
                
                <!-- Filters -->
                <div class="filters-bar">
                    <div class="filter-group">
                        <label>Категория:</label>
                        <select id="categoryFilter" onchange="filterProducts()">
                            <option value="">Все категории</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label>Статус:</label>
                        <select id="statusFilter" onchange="filterProducts()">
                            <option value="">Все</option>
                            <option value="instock">В наличии</option>
                            <option value="low">Заканчивается</option>
                            <option value="out">Нет в наличии</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label>Сортировка:</label>
                        <select id="sortFilter" onchange="sortProducts()">
                            <option value="name">По названию</option>
                            <option value="stock">По остатку</option>
                            <option value="category">По категории</option>
                        </select>
                    </div>
                </div>
                
                <!-- Table -->
                <div class="inventory-table-container">
                    <table class="inventory-table">
                        <thead>
                            <tr>
                                <th>Товар</th>
                                <th>Категория</th>
                                <th>Остаток</th>
                                <th>Мин. уровень</th>
                                <th>Статус</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody id="inventoryTableBody">
                            <!-- Filled by JS -->
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>
    
    <script>
        // Mock inventory data (will be replaced with real API)
        let inventory = [];
        let categories = [];
        
        // Load data
        async function loadInventory() {
            try {
                // Load categories and products
                const catsResponse = await fetch('/api/menu/categories');
                categories = await catsResponse.json();
                
                // Generate mock inventory for products
                inventory = [];
                categories.forEach(cat => {
                    cat.products?.forEach(prod => {
                        // Generate random stock levels
                        const minLevel = Math.floor(Math.random() * 10) + 5;
                        const currentStock = Math.floor(Math.random() * 30);
                        
                        inventory.push({
                            id: prod.id,
                            name: prod.name_ru,
                            category: cat.name_ru,
                            image: prod.image_url,
                            currentStock: currentStock,
                            minLevel: minLevel,
                            unit: 'шт',
                            lastUpdated: new Date().toISOString()
                        });
                    });
                });
                
                // Populate category filter
                const catSelect = document.getElementById('categoryFilter');
                catSelect.innerHTML = '<option value="">Все категории</option>' +
                    categories.map(c => `<option value="${c.name_ru}">${c.name_ru}</option>`).join('');
                
                updateStats();
                renderTable();
                checkAlerts();
                
            } catch (err) {
                console.error('Inventory load error:', err);
            }
        }
        
        // Update stats
        function updateStats() {
            const total = inventory.length;
            const inStock = inventory.filter(i => i.currentStock > i.minLevel).length;
            const low = inventory.filter(i => i.currentStock > 0 && i.currentStock <= i.minLevel).length;
            const out = inventory.filter(i => i.currentStock === 0).length;
            
            document.getElementById('totalItems').textContent = total;
            document.getElementById('inStock').textContent = inStock;
            document.getElementById('lowStock').textContent = low;
            document.getElementById('outOfStock').textContent = out;
        }
        
        // Render table
        function renderTable() {
            const tbody = document.getElementById('inventoryTableBody');
            const filtered = getFilteredProducts();
            
            if (filtered.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="6" style="text-align: center; padding: 40px; color: var(--text-secondary);">
                            Нет товаров для отображения
                        </td>
                    </tr>
                `;
                return;
            }
            
            tbody.innerHTML = filtered.map(item => {
                const percentage = Math.min(100, (item.currentStock / (item.minLevel * 2)) * 100);
                let statusClass = 'high';
                let statusBadge = 'instock';
                let statusText = 'В наличии';
                
                if (item.currentStock === 0) {
                    statusClass = 'low';
                    statusBadge = 'out';
                    statusText = 'Нет в наличии';
                } else if (item.currentStock <= item.minLevel) {
                    statusClass = 'medium';
                    statusBadge = 'low';
                    statusText = 'Заканчивается';
                }
                
                return `
                    <tr>
                        <td>
                            <div class="product-cell">
                                <img src="${item.image || 'https://via.placeholder.com/48'}" class="product-image" alt="">
                                <div class="product-info">
                                    <h4>${item.name}</h4>
                                    <span>ID: ${item.id}</span>
                                </div>
                            </div>
                        </td>
                        <td>${item.category}</td>
                        <td>
                            <div class="stock-indicator">
                                <div class="stock-bar">
                                    <div class="stock-fill ${statusClass}" style="width: ${percentage}%"></div>
                                </div>
                                <span class="stock-value">${item.currentStock} ${item.unit}</span>
                            </div>
                        </td>
                        <td>${item.minLevel} ${item.unit}</td>
                        <td><span class="status-badge ${statusBadge}">${statusText}</span></td>
                        <td>
                            <div class="action-btns">
                                <button class="action-btn" onclick="adjustStock(${item.id}, 1)" title="Приход">+</button>
                                <button class="action-btn" onclick="adjustStock(${item.id}, -1)" title="Расход">−</button>
                                <button class="action-btn" onclick="editProduct(${item.id})" title="Редактировать">✏️</button>
                            </div>
                        </td>
                    </tr>
                `;
            }).join('');
        }
        
        // Get filtered products
        function getFilteredProducts() {
            let filtered = [...inventory];
            
            // Search filter
            const search = document.getElementById('searchInput').value.toLowerCase();
            if (search) {
                filtered = filtered.filter(i => i.name.toLowerCase().includes(search));
            }
            
            // Category filter
            const category = document.getElementById('categoryFilter').value;
            if (category) {
                filtered = filtered.filter(i => i.category === category);
            }
            
            // Status filter
            const status = document.getElementById('statusFilter').value;
            if (status) {
                if (status === 'instock') {
                    filtered = filtered.filter(i => i.currentStock > i.minLevel);
                } else if (status === 'low') {
                    filtered = filtered.filter(i => i.currentStock > 0 && i.currentStock <= i.minLevel);
                } else if (status === 'out') {
                    filtered = filtered.filter(i => i.currentStock === 0);
                }
            }
            
            return filtered;
        }
        
        // Filter products
        function filterProducts() {
            renderTable();
        }
        
        // Sort products
        function sortProducts() {
            const sort = document.getElementById('sortFilter').value;
            
            if (sort === 'name') {
                inventory.sort((a, b) => a.name.localeCompare(b.name));
            } else if (sort === 'stock') {
                inventory.sort((a, b) => a.currentStock - b.currentStock);
            } else if (sort === 'category') {
                inventory.sort((a, b) => a.category.localeCompare(b.category));
            }
            
            renderTable();
        }
        
        // Check for low stock alerts
        function checkAlerts() {
            const lowStock = inventory.filter(i => i.currentStock <= i.minLevel && i.currentStock > 0);
            const outOfStock = inventory.filter(i => i.currentStock === 0);
            
            const totalAlerts = lowStock.length + outOfStock.length;
            
            if (totalAlerts > 0) {
                document.getElementById('alertBanner').style.display = 'flex';
                document.getElementById('alertText').textContent = 
                    `${outOfStock.length} товаров нет в наличии, ${lowStock.length} заканчивается`;
            } else {
                document.getElementById('alertBanner').style.display = 'none';
            }
        }
        
        // Adjust stock
        function adjustStock(productId, delta) {
            const item = inventory.find(i => i.id === productId);
            if (!item) return;
            
            const newStock = item.currentStock + delta;
            if (newStock < 0) {
                alert('Остаток не может быть отрицательным!');
                return;
            }
            
            item.currentStock = newStock;
            item.lastUpdated = new Date().toISOString();
            
            updateStats();
            renderTable();
            checkAlerts();
        }
        
        // Edit product
        function editProduct(productId) {
            const item = inventory.find(i => i.id === productId);
            if (!item) return;
            
            const newMin = prompt(`Минимальный уровень для "${item.name}":`, item.minLevel);
            if (newMin !== null && !isNaN(newMin)) {
                item.minLevel = parseInt(newMin);
                renderTable();
                checkAlerts();
            }
        }
        
        // Open stock modal
        function openStockModal() {
            alert('Функция прихода товара будет добавлена позже');
        }
        
        // Export inventory
        function exportInventory() {
            const csv = [
                ['ID', 'Название', 'Категория', 'Остаток', 'Мин. уровень', 'Ед. изм.'].join(';'),
                ...inventory.map(i => [i.id, i.name, i.category, i.currentStock, i.minLevel, i.unit].join(';'))
            ].join('\n');
            
            const blob = new Blob(['\ufeff' + csv], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = `inventory_${new Date().toISOString().split('T')[0]}.csv`;
            link.click();
        }
        
        // Auto refresh every 30 seconds
        setInterval(loadInventory, 30000);
        
        // Initial load
        loadInventory();
    </script>
    </div>
    
    <script>
        // Toggle section expand/collapse
        function toggleSection(header) {
            const section = header.parentElement;
            section.classList.toggle('expanded');
            
            // Save state to localStorage
            const sectionName = section.dataset.section;
            const isExpanded = section.classList.contains('expanded');
            localStorage.setItem(, isExpanded);
        }
        
        // Restore section states from localStorage
        function restoreSectionStates() {
            document.querySelectorAll('.nav-section').forEach(section => {
                const sectionName = section.dataset.section;
                const savedState = localStorage.getItem();
                // Only restore if explicitly saved, otherwise use default (collapsed)
                if (savedState !== null) {
                    if (savedState === 'true') {
                        section.classList.add('expanded');
                    } else {
                        section.classList.remove('expanded');
                    }
                }
            });
        }
        
        // Mobile sidebar toggle
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebarOverlay');
            sidebar.classList.toggle('open');
            overlay.classList.toggle('open');
        }
        
        function closeSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebarOverlay');
            sidebar.classList.remove('open');
            overlay.classList.remove('open');
        }
        
        // Initialize
        document.addEventListener('DOMContentLoaded', function() {
            restoreSectionStates();
        });
    </script>
</body>
</html>
